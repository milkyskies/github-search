# optional — GitHub personal access token (classic or fine-grained, no scopes needed for public search).
# Raises the GitHub API rate limit (search: 10 -> 30 req/min, core: 60 -> 5000 req/hr).
# The app works without it, just with lower limits. Kept server-side only.
GITHUB_TOKEN=

# optional — overrides the GitHub REST base URL (default https://api.github.com).
# Set by the Playwright e2e run to point at the local mock server (tests/mock-github/server.ts).
GITHUB_API_BASE_URL=
